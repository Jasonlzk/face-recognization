# ===== CloudBase AI 网关配置 =====
# 网关端点（OpenAI 兼容的 chat/completions），已固定为你的环境
VITE_CLOUDBASE_AI_ENDPOINT=https://super-coding-7g3ppgel159a8f2f.api.tcloudbasegateway.com/v1/ai/cloudbase/v1/chat/completions

# 调用凭证（Bearer）：在 CloudBase 控制台 -> 你的环境(super-coding-7g3ppgel159a8f2f) -> AI -> 网关/密钥 中创建后填入
VITE_CLOUDBASE_AI_API_KEY=

# 可选：指定模型（默认 deepseek-v4-flash，需在该环境的 AI 中已启用）
VITE_CLOUDBASE_AI_MODEL=deepseek-v4-flash
